{
  "name": "kodr2",
  "version": "0.2.94",
  "description": "A one-shot coding harness for local LM Studio models",
  "keywords": [
    "coding-agent",
    "lm-studio",
    "local-llm"
  ],
  "author": "Paul Kohler",
  "license": "MIT",
  "homepage": "https://github.com/paulkohler/kodr2#readme",
  "bugs": {
    "url": "https://github.com/paulkohler/kodr2/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paulkohler/kodr2.git"
  },
  "type": "module",
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "kodr": "./bin/kodr.mjs"
  },
  "scripts": {
    "assert:zero-deps": "node scripts/assert-zero-deps.mjs",
    "version:set": "node scripts/set-version.mjs",
    "version:check": "node scripts/set-version.mjs --check",
    "pretest": "npm run assert:zero-deps",
    "test": "node --test test/*.test.mjs",
    "eval": "node --test eval/*.eval.mjs",
    "arena": "node eval/arena/run.mjs",
    "inspect-run": "node scripts/inspect-run.mjs",
    "install-local": "node bin/install-local.mjs",
    "check": "find bin src -name '*.mjs' -exec node --check {} +",
    "check:biome": "node scripts/require-biome.mjs",
    "preformat": "npm run check:biome",
    "format": "biome format --write bin src test eval specs *.md *.json",
    "preformat:check": "npm run check:biome",
    "format:check": "biome format bin src test eval specs *.md *.json",
    "prelint": "npm run check:biome",
    "lint": "biome lint bin src test eval",
    "prelint:fix": "npm run check:biome",
    "lint:fix": "biome lint --write bin src test eval",
    "prepack": "npm run assert:zero-deps",
    "prepublishOnly": "npm run assert:zero-deps && npm run version:set"
  },
  "engines": {
    "node": ">=22"
  }
}
